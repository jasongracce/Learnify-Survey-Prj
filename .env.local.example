# Supabase — create a project at https://supabase.com
# Project URL + anon key (client bundle; keep public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Required by the /api/survey/submit route. Found in Supabase dashboard:
# Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — survey confirmation emails
# In production, RESEND_API_KEY is injected by the Vercel ↔ Resend
# Marketplace integration. Set this locally for dev only (get a key
# from https://resend.com/api-keys).
RESEND_API_KEY=
# From-address. Defaults to "Learnify Team <noreply@learnify.academy>"
# in lib/email.ts if unset. For preview testing before learnify.academy
# is verified on Resend, set this to onboarding@resend.dev.
EMAIL_FROM=
