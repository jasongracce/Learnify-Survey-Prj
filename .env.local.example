# Supabase — create a project at https://supabase.com
# Project URL + anon key (client bundle; keep public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Required by the /api/survey/submit route. Found in Supabase dashboard:
# Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
